--- !u!114 &873819363
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 873819362}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 52721e18194b0c8419d0b484adcd3f22, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ISwingingContactHazard
  Notes: "This hazard script can be attached to an object which will then oscillate
    between the 'RotationTargets' in the list. Only two rotation targets can be put
    in the list. A collider set to 'trigger' should be attached to the game object
    at the 'pointy' part of the model -- alternatively, multiple child objects with
    IContactDamageHazard can be added to add multiple damage contact points. \n Good
    for making pendulum blade hazards or spiked gates."
  damageAmount: 0
  rotationTargets:
  - {x: 55, y: 90, z: 0}
  - {x: -55, y: 90, z: 0}
  hazardActive: 1
  swingTimer: 0
  swingSpeed: 5
  swingClip: {fileID: 0}
  hitPlayerClip: {fileID: 0}
