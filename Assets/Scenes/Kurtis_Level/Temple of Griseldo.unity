  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ToggleColliderActivator
  DeveloperNote: "This Activator will detect any object with a 'CanTriggerCollisionActivator'
    component that moves into it's trigger collider. \nOnce it has activated the
    attached transmitter, it will activate it again if the player / other object
    that is 'pressing' it moves away. \nUse case example: A door which requires a
    moveable box to be placed on this Activator to keep the door open."
  activatorReadyPosition: {x: 0, y: 0, z: 0}
  activatorUsedPosition: {x: 0, y: 0, z: 0}
  activatorMoveSpeed: 0
  snapDistance: 0.2
  activatedClip: {fileID: 0}
  resetClip: {fileID: 0}
