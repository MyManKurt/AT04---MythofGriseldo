  m_Script: {fileID: 11500000, guid: 13b33d2a350adf248b757193e7b3bffc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  Notes: "This hazard will send out a projectile which causes damage to the player
    on contact. \n The damage value should be a negative number so as to actually
    subtract health from the player. \n To set up in the scene, you need: \n 1. An
    empty game object with this script attached, placed where you want the spawner.
    \n 2. A child object to be assigned as the spawnpoint, pointing in the direction
    that you want the projectile to go. \n 3. The projectile prefab component assigned
    to the appropriate slot. \n 4. (Optional) a visual mesh for the spawn point as
    a child object, with no collider as the collider would potentially impact the
    projectile when it spawns depending on the placement."
  projectileDamage: 0
  projectileVelocity: {x: 0, y: 0, z: 0}
  projectileSpeed: 0
  projectilePrefab: {fileID: 0}
  projectileSpawnPoint: {fileID: 0}
  shootProjectileClip: {fileID: 0}
